APP_NAME=AI English Learner
APP_HOST=127.0.0.1
APP_PORT=8099
APP_SECRET_KEY=replace-this-with-a-random-secret
SESSION_TTL_HOURS=168
OTP_TTL_MINUTES=10
FIRST_REVIEW_MINUTES=60
REVIEW_PROMPT_INTERVAL_SECONDS=90
QUIZ_RETAKE_MINUTES=20
MAX_UPLOAD_BYTES=26214400

# Runtime app state only: SQLite database plus uploaded images.
# Keep model weights out of this folder.
APP_DATA_DIR=app_data
UPLOADS_DIR=
DATABASE_PATH=

# Choose one: vllm, openai, or demo
AI_BACKEND=vllm

# vLLM server settings.
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=local-dev
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct-AWQ
VLLM_MAX_CONCURRENCY=8
VLLM_BATCH_INTERVAL_MS=30
VLLM_BATCH_MAX_SIZE=8
VLLM_TIMEOUT_SECONDS=120
INFERENCE_MAX_NEW_TOKENS=180
INFERENCE_TEMPERATURE=0.0
IMAGE_MIN_PIXELS=100352
IMAGE_MAX_PIXELS=100352

# Set DEMO_MODE=false and add a real key to enable hosted image analysis.
DEMO_MODE=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# SMTP is optional. If not configured, OTP codes are printed in the server logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
COOKIE_SECURE=false

# Development only: bypass signup/login and use a local verified user.
DISABLE_LOGIN_FLOW=false
DEV_USER_EMAIL=dev@local.test
DEV_USER_NAME=Dev Learner
